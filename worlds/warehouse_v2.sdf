<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="warehouse">

    <!-- ═══════════════════════════════════════════
         PHYSICS & PLUGINS
    ═══════════════════════════════════════════ -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- Scene -->
    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- Lights -->
    <light name="light_0" type="point">
      <pose>0 0 6 0 0 0</pose>
      <diffuse>0.9 0.9 0.85 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>20</range><linear>0.05</linear></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>
    <light name="light_1" type="point">
      <pose>10 10 6 0 0 0</pose>
      <diffuse>0.9 0.9 0.85 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>20</range><linear>0.05</linear></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>
    <light name="light_2" type="point">
      <pose>-10 10 6 0 0 0</pose>
      <diffuse>0.9 0.9 0.85 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>20</range><linear>0.05</linear></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>
    <light name="light_3" type="point">
      <pose>0 -10 6 0 0 0</pose>
      <diffuse>0.9 0.9 0.85 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>20</range><linear>0.05</linear></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- ═══════════════════════════════════════════
         GROUND PLANE
    ═══════════════════════════════════════════ -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>50 50</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>50 50</size></plane></geometry>
          <material>
            <ambient>0.55 0.55 0.55 1</ambient>
            <diffuse>0.6 0.6 0.6 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════
         OUTER WALLS
    ═══════════════════════════════════════════ -->
    <model name="wall_south_L">
      <static>true</static>
      <pose>-5.1 -12 1.75 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>9.8 0.2 3.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>9.8 0.2 3.5</size></box></geometry>
          <material><ambient>0.75 0.72 0.68 1</ambient><diffuse>0.75 0.72 0.68 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wall_south_R">
      <static>true</static>
      <pose>5.1 -12 1.75 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>9.8 0.2 3.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>9.8 0.2 3.5</size></box></geometry>
          <material><ambient>0.75 0.72 0.68 1</ambient><diffuse>0.75 0.72 0.68 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wall_north">
      <static>true</static>
      <pose>0 12 1.75 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>20 0.2 3.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>20 0.2 3.5</size></box></geometry>
          <material><ambient>0.75 0.72 0.68 1</ambient><diffuse>0.75 0.72 0.68 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wall_west">
      <static>true</static>
      <pose>-10 0 1.75 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 24 3.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.2 24 3.5</size></box></geometry>
          <material><ambient>0.75 0.72 0.68 1</ambient><diffuse>0.75 0.72 0.68 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wall_east">
      <static>true</static>
      <pose>10 0 1.75 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 24 3.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.2 24 3.5</size></box></geometry>
          <material><ambient>0.75 0.72 0.68 1</ambient><diffuse>0.75 0.72 0.68 1</diffuse></material></visual>
      </link>
    </model>

