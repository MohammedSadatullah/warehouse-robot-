        <visual name="vis"><geometry><box><size>0.5 2.0 1.8</size></box></geometry>
          <material><ambient>0.55 0.42 0.28 1</ambient><diffuse>0.55 0.42 0.28 1</diffuse></material></visual></link></model>

    <!-- Boxes on shelves -->
    <model name="box_A1a"><static>true</static><pose>-7.15 2.5 1.85 0 0 0</pose><link name="link">
        <collision name="col"><geometry><box><size>0.3 0.3 0.3</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.3 0.3 0.3</size></box></geometry>
          <material><ambient>0.8 0.6 0.1 1</ambient><diffuse>0.8 0.6 0.1 1</diffuse></material></visual></link></model>
    <model name="box_B2a"><static>true</static><pose>-5.65 5.6 1.85 0 0 0</pose><link name="link">
        <collision name="col"><geometry><box><size>0.3 0.4 0.25</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.3 0.4 0.25</size></box></geometry>
          <material><ambient>0.2 0.5 0.8 1</ambient><diffuse>0.2 0.5 0.8 1</diffuse></material></visual></link></model>
    <model name="box_C3a"><static>true</static><pose>7.15 9.3 1.85 0 0 0</pose><link name="link">
        <collision name="col"><geometry><box><size>0.35 0.3 0.3</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.35 0.3 0.3</size></box></geometry>
          <material><ambient>0.8 0.2 0.2 1</ambient><diffuse>0.8 0.2 0.2 1</diffuse></material></visual></link></model>

    <!-- Workbench + packing station -->
    <model name="workbench"><static>true</static><pose>7.5 -8 0.45 0 0 0</pose><link name="link">
        <collision name="col"><geometry><box><size>2.0 0.8 0.9</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>2.0 0.8 0.9</size></box></geometry>
          <material><ambient>0.65 0.5 0.35 1</ambient><diffuse>0.65 0.5 0.35 1</diffuse></material></visual></link></model>
    <model name="packing_box_1"><static>true</static><pose>7.2 -8 1.0 0 0 0</pose><link name="link">
        <collision name="col"><geometry><box><size>0.4 0.4 0.4</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.4 0.4 0.4</size></box></geometry>
          <material><ambient>0.85 0.75 0.5 1</ambient><diffuse>0.85 0.75 0.5 1</diffuse></material></visual></link></model>

    <!-- Charging dock -->
    <model name="charging_dock"><static>true</static><pose>0 -10.5 0.1 0 0 0</pose><link name="link">
        <collision name="col"><geometry><box><size>0.6 0.4 0.2</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.6 0.4 0.2</size></box></geometry>
          <material><ambient>0.1 0.6 0.2 1</ambient><diffuse>0.1 0.6 0.2 1</diffuse></material></visual></link></model>

    <!-- ═══════════════════════════════════════════
         DYNAMIC OBSTACLES
         Using non-static models driven by
         gz::sim::systems::OdometryPublisher
         and a pose publisher script, OR
         simple kinematic bodies with
      LinearBatteryPlugin for motion.

         For Gazebo Harmonic the most reliable
         approach for pedestrian-style obstacles
         is a box model with a scripted pose
         published via the /world/.../set_pose
         service from an external Python node.

         These models are NON-static cylinders
         (human silhouette: 0.45 m dia, 1.7 m tall)
         that will be moved by dynamic_actors.py
    ═══════════════════════════════════════════ -->

    


<!-- ─────────────── Pedestrian 1 (Centre aisle) ─────────────── -->
<model name="pedestrian_1">
  <static>false</static>
  <pose>0 -8 0.85 0 0 0</pose>

  <link name="link">
    <gravity>false</gravity>

    <inertial>
      <mass>70</mass>
      <inertia>
        <ixx>3.5</ixx><iyy>3.5</iyy><izz>1.0</izz>
        <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
      </inertia>
    </inertial>

    <collision name="col">
      <geometry>
        <cylinder>
          <radius>0.22</radius>
          <length>1.7</length>
        </cylinder>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
          </ode>
        </friction>
      </surface>
    </collision>

    <visual name="vis">
      <geometry>
        <cylinder>
          <radius>0.22</radius>
          <length>1.7</length>
        </cylinder>
      </geometry>
      <material>
        <ambient>0.9 0.5 0.1 1</ambient>
        <diffuse>0.9 0.5 0.1 1</diffuse>
      </material>
    </visual>
  </link>
</model>


<!-- ─────────────── Pedestrian 2 (West aisle) ─────────────── -->
<model name="pedestrian_2">
  <static>false</static>
  <pose>-6.75 2 0.85 0 0 0</pose>

  <link name="link">
    <gravity>false</gravity>

    <inertial>
      <mass>70</mass>
      <inertia>
