        </cylinder>
      </geometry>
      <material>
        <ambient>0.2 0.6 1.0 1</ambient>
        <diffuse>0.2 0.6 1.0 1</diffuse>
      </material>
    </visual>
  </link>
</model>


<!-- ─────────────── Pedestrian 3 (Crossing) ─────────────── -->
<model name="pedestrian_3">
  <static>false</static>
  <pose>-8.5 0 0.85 0 0 0</pose>

  <link name="link">
    <gravity>false</gravity>

    <inertial>
      <mass>70</mass>
