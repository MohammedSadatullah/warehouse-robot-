    <visual name="vis">
      <geometry>
        <cylinder>
          <radius>
0.22</radius>
          <length>1.7</length>
        </cylinder>
      </geometry>
      <material>
        <ambient>0.3 1.0 0.3 1</ambient>
        <diffuse>0.3 1.0 0.3 1</diffuse>
