        <visual name="vis"><geometry><box><size>0.5 2.0 1.8</size></box></geometry>
          <material><ambient>0.55 0.42 0.28 1</ambient><diffuse>0.55 0.42 0.28 1</diffuse></material></visual></link></model>
    <model name="shelf_B2"><static>true</static><pose>-6.0 6 0.9 0 0 0</pose><link name="link">
        <collision name="col"><geometry><box><size>0.5 2.0 1.8</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.5 2.0 1.8</size></box></geometry>
          <material><ambient>0.55 0.42 0.28 1</ambient><diffuse>0.55 0.42 0.28 1</diffuse></material></visual></link></model>
    <model name="shelf_B3"><static>true</static><pose>-6.0 9 0.9 0 0 0</pose><link name="link">
        <collision name="col"><geometry><box><size>0.5 2.0 1.8</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.5 2.0 1.8</size></box></geometry>
          <material><ambient>0.55 0.42 0.28 1</ambient><diffuse>0.55 0.42 0.28 1</diffuse></material></visual></link></model>
    <model name="shelf_C1"><static>true</static><pose>7.5 3 0.9 0 0 0</pose><link name="link">
        <collision name="col"><geometry><box><size>0.5 2.0 1.8</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.5 2.0 1.8</size></box></geometry>
          <material><ambient>0.6 0.45 0.3 1</ambient><diffuse>0.6 0.45 0.3 1</diffuse></material></visual></link></model>
    <model name="shelf_C2"><static>true</static><pose>7.5 6 0.9 0 0 0</pose><link name="link">
        <collision name="col"><geometry><box><size>0.5 2.0 1.8</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.5 2.0 1.8</size></box></geometry>
          <material><ambient>0.6 0.45 0.3 1</ambient><diffuse>0.6 0.45 0.3 1</diffuse></material></visual></link></model>
    <model name="shelf_C3"><static>true</static><pose>7.5 9 0.9 0 0 0</pose><link name="link">
        <collision name="col"><geometry><box><size>0.5 2.0 1.8</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.5 2.0 1.8</size></box></geometry>
          <material><ambient>0.6 0.45 0.3 1</ambient><diffuse>0.6 0.45 0.3 1</diffuse></material></visual></link></model>
    <model name="shelf_D1"><static>true</static><pose>6.0 3 0.9 0 0 0</pose><link name="link">
        <collision name="col"><geometry><box><size>0.5 2.0 1.8</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.5 2.0 1.8</size></box></geometry>
          <material><ambient>0.55 0.42 0.28 1</ambient><diffuse>0.55 0.42 0.28 1</diffuse></material></visual></link></model>
    <model name="shelf_D2"><static>true</static><pose>6.0 6 0.9 0 0 0</pose><link name="link">
